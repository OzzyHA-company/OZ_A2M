# OZ_A2M Environment Configuration

# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
API_KEY_SALT=your-salt-change-in-production

# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_KEEPALIVE=60

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Elasticsearch
ES_HOST=localhost
ES_PORT=9200
ES_INDEX_PREFIX=oz_a2m

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:pass@localhost:5432/oz_a2m

# Exchange API (제7부서 - freqtrade)
EXCHANGE_API_KEY=your-exchange-api-key
EXCHANGE_API_SECRET=your-exchange-api-secret
EXCHANGE_NAME=binance

# LLM Gateway
ANTHROPIC_API_KEY=sk-ant-your-key
OPENAI_API_KEY=sk-your-key
GEMINI_API_KEY=your-key

# Monitoring
NETDATA_CLAIM_TOKEN=
NETDATA_CLAIM_URL=https://app.netdata.cloud

# Trading
INITIAL_CAPITAL=10000
MAX_POSITION_PCT=0.1
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json