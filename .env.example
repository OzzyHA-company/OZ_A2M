# OZ_A2M Environment Configuration
# 마스터 문서: docs/OZ_A2M_MASTER.md

# ─── Application ───────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── 거래소 (Exchange) ─────────────────────────────
# Binance
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret

# Bybit
BYBIT_API_KEY=your-bybit-api-key
BYBIT_API_SECRET=your-bybit-api-secret

# ─── Solana ────────────────────────────────────────
HELIUS_API_KEY=your-helius-api-key
PHANTOM_WALLET_MAIN=your-main-wallet-private-key
PHANTOM_WALLET_A=hyperliquid-wallet-private-key
PHANTOM_WALLET_B=pumpfun-wallet-private-key
PHANTOM_WALLET_C=gmgn-wallet-private-key

# ─── 예측시장 (Prediction Markets) ───────────────────
METAMASK_ADDRESS=your-metamask-polygon-address
IBKR_ACCOUNT_ID=your-ibkr-account-id
IBKR_PORT=7497

# ─── LLM Gateway ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key
OPENAI_API_KEY=sk-your-key
GEMINI_API_KEY=your-gemini-key
GROQ_API_KEY=your-groq-key

# ─── 알림 (Notifications) ──────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ─── 인프라 (Infrastructure) ───────────────────────
# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_KEEPALIVE=60

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092,localhost:9093

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:pass@localhost:5432/oz_a2m

# ─── 거래 설정 (Trading Settings) ──────────────────
DRY_RUN=true
MAX_POSITION_PCT=0.1
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04
